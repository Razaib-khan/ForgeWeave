{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "mcpServers": {
    "forgeweave": {
      "name": "ForgeWeave",
      "description": "ForgeWeave Control Plane — 12 forge.* tools",
      "command": "forge",
      "args": [
        "mcp"
      ],
      "transport": "stdio",
      "env": {
        "FORGE_PROJECT_DIR": "${workspaceFolder}",
        "FORGE_TUI": "opencode"
      }
    }
  }
}
