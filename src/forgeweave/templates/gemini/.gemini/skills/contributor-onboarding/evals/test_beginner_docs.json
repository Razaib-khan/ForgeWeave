{
  "eval_id": "test-beginner-docs",
  "skill_id": "contributor-onboarding",
  "description": "Verify that a beginner interested in documentation receives setup instructions and issue suggestions",
  "input": {
    "contributor_level": "beginner",
    "interest_area": "docs",
    "has_setup_env": false
  },
  "checks": [
    {
      "type": "reference_exists",
      "path": "../../../CONTRIBUTING.md",
      "description": "CONTRIBUTING.md exists for reference"
    },
    {
      "type": "content_match",
      "path": "SKILL.md",
      "pattern": "## Exact Workflow Steps",
      "description": "SKILL.md contains detailed workflow steps"
    },
    {
      "type": "content_match",
      "path": "SKILL.md",
      "pattern": "good-first-issue",
      "description": "SKILL.md references beginner-friendly issues"
    }
  ],
  "expected_status": "SUCCESS"
}
