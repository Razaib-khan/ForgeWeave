{
  "eval_id": "<eval-name>",
  "skill_id": "<target-skill-id>",
  "description": "What this eval validates",
  "input": {
    "<input-name>": "<input-value>"
  },
  "checks": [
    {
      "type": "file_exists",
      "path": "<expected-output-path>",
      "description": "Check that the expected output file was created"
    },
    {
      "type": "content_match",
      "path": "<output-path>",
      "pattern": "<expected-pattern>",
      "description": "Check that output contains expected content"
    },
    {
      "type": "exit_code",
      "expected": 0,
      "description": "Check that the skill exits successfully"
    }
  ],
  "expected_status": "SUCCESS | PARTIAL | FAILED"
}
