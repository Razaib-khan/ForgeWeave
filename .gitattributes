# Auto-detect text files and set line endings
* text=auto

# Python source files
*.py text diff=python
*.pyx text diff=python
*.pxd text diff=python
*.pxi text diff=python

# Documentation
*.md text diff=markdown
*.rst text diff=rst
*.txt text

# Configuration files
*.yaml text
*.yml text
*.json text
*.toml text
*.cfg text
*.ini text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Lock files
uv.lock -text
*.lock -text

# Binary files
*.pyc binary
*.pyo binary
*.pyd binary
*.so binary
*.dll binary
*.dylib binary
*.class binary

# Generated files
.gitignore text
.gitattributes text
